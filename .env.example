# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# --- Supabase (blog likes, etc.) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Contact form (Gmail SMTP via nodemailer) ---
# Gmail account the form sends FROM. Must have 2-Step Verification enabled.
GMAIL_USER=you@gmail.com
# 16-char Google "App Password" (NOT your normal password).
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-16-char-app-password
# Where contact-form messages are delivered (defaults to GMAIL_USER if blank).
CONTACT_EMAIL_TO=you@gmail.com

# --- GitHub auto-pulled projects (optional) ---
# Public repos with a "Website"/homepage link are listed automatically.
# A token is only needed to raise the 60 requests/hour unauthenticated limit.
# GITHUB_TOKEN=
