# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# --- Supabase (blog likes, etc.) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Contact form (Resend) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Address the form sends FROM — must use a domain verified in Resend.
# Optional: defaults to "Saurav Portfolio <contact@sauravksingh.in>" if blank.
RESEND_FROM=Saurav Portfolio <contact@sauravksingh.in>
# Where contact-form messages are delivered (your inbox).
CONTACT_EMAIL_TO=you@gmail.com

# --- GitHub auto-pulled projects (optional) ---
# Public repos with a "Website"/homepage link are listed automatically.
# A token is only needed to raise the 60 requests/hour unauthenticated limit.
# GITHUB_TOKEN=

# --- Chatbot AI (Gemini Flash, optional) ---
# Powers smart, conversational replies in the "Sonic" chat widget.
# Get a free key: https://aistudio.google.com/apikey
# Without it (or when rate-limited) the bot falls back to built-in generic replies.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
